---
interface Props {
  class?: string;
  showText?: boolean;
}

const { class: className = "", showText = true } = Astro.props;
---

<a href={`${import.meta.env.BASE_URL}`} class:list={["flex items-center gap-2.5 group", className]} aria-label="Repovera home">
  <svg
    viewBox="0 0 32 32"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
    class="h-8 w-8 transition-transform duration-200 group-hover:scale-105"
    aria-hidden="true"
  >
    <rect width="32" height="32" rx="8" fill="#6366f1" />
    <path
      d="M10 8h6.5c2.5 0 4.5 1.8 4.5 4.2 0 1.8-1.1 3.3-2.8 3.9L22 24h-3.8l-3.2-7H13v7h-3V8zm3 2.8v4.4h3.2c1.2 0 2-0.9 2-2.2s-0.8-2.2-2-2.2H13z"
      fill="white"
    />
  </svg>
  {
    showText && (
      <span class="text-lg font-semibold tracking-tight text-[var(--color-text)]">Repovera</span>
    )
  }
</a>
