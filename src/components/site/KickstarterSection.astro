---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import Reveal from "@/components/ui/Reveal.astro";
import { KICKSTARTER_URL, GITHUB_URL } from "@/consts/site";
---

<section id="kickstarter" class="py-20 md:py-28 bg-[var(--color-surface)]/50">
  <Container>
    <div class="max-w-3xl mx-auto text-center">
      <Reveal>
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-kickstarter)] mb-3">
          Support the launch
        </p>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-5">
          Back independent developer infrastructure
        </h2>
        <p class="text-base sm:text-lg text-[var(--color-text-secondary)] leading-relaxed mb-4 max-w-2xl mx-auto">
          Repovera is being built outside the conventional venture-capital growth model. By backing the
          Kickstarter campaign, you support the creation of privacy-first, transparent, and legally
          grounded code infrastructure — built to last, not to flip.
        </p>
        <p class="text-sm text-[var(--color-text-tertiary)] leading-relaxed mb-8 max-w-xl mx-auto">
          Early backers help ensure the platform is developed with long-term sustainability in mind.
          You are not just funding a product — you are supporting a principle: that developer
          infrastructure should respect its users.
        </p>
      </Reveal>

      <Reveal delay={100}>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-6">
          <Button variant="kickstarter" size="lg" href={KICKSTARTER_URL} target="_blank">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.204 8.086l-5.792 3.376V7.696L18.204 4v4.086zM12.412 12.622l5.792 3.376V20l-5.792-3.766v-3.612zM5.796 4.766v14.468L10.572 16V8L5.796 4.766z"/>
            </svg>
            Back Repovera on Kickstarter
          </Button>
          <Button variant="github" size="lg" href={GITHUB_URL} target="_blank">
            <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            Explore on GitHub
          </Button>
        </div>
      </Reveal>

      <Reveal delay={150}>
        <p class="text-xs text-[var(--color-text-tertiary)]">
          The Kickstarter campaign link will be updated when the campaign launches.
          Follow the GitHub repository for the latest updates.
        </p>
      </Reveal>
    </div>
  </Container>
</section>
