---
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Badge from "@/components/ui/Badge.astro";
import Reveal from "@/components/ui/Reveal.astro";
import { features } from "@/data/features";

const iconPaths: Record<string, string> = {
  "git-branch": "M6 3v12M18 9a3 3 0 100-6 3 3 0 000 6zM6 21a3 3 0 100-6 3 3 0 000 6zM18 9a9 9 0 01-9 9",
  users: "M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2M9 7a4 4 0 100-8 4 4 0 000 8zM23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75",
  "message-square": "M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z",
  shield: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z",
  eye: "M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8zM12 9a3 3 0 100 6 3 3 0 000-6z",
  scale: "M12 3v18M3 7l9-4 9 4M3 7v4l9 4 9-4V7",
  building: "M3 21h18M5 21V7l8-4v18M13 21V3l6 4v14",
  globe: "M12 2a10 10 0 100 20 10 10 0 000-20zM2 12h20M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10A15.3 15.3 0 0112 2z",
  key: "M21 2l-2 2m-7.61 7.61a5.5 5.5 0 11-7.78 7.78 5.5 5.5 0 017.78-7.78zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4",
  "layout-grid": "M3 3h7v7H3zM14 3h7v7h-7zM14 14h7v7h-7zM3 14h7v7H3z",
  zap: "M13 2L3 14h9l-1 8 10-12h-9l1-8z",
  puzzle: "M19.439 7.85c-.049.322.059.648.289.878l1.568 1.568c.47.47.706 1.087.706 1.704s-.235 1.233-.706 1.704l-1.611 1.611a.98.98 0 01-.837.276c-.47-.07-.802-.48-.968-.925a2.501 2.501 0 10-3.214 3.214c.446.166.855.497.925.968a.979.979 0 01-.276.837l-1.61 1.611a2.404 2.404 0 01-1.705.707 2.402 2.402 0 01-1.704-.707l-1.568-1.568a1.026 1.026 0 00-.877-.29c-.493.074-.84.504-1.02.968a2.5 2.5 0 11-3.237-3.237c.464-.18.894-.527.967-1.02a1.026 1.026 0 00-.289-.877l-1.568-1.568A2.402 2.402 0 011.998 12c0-.617.236-1.234.706-1.704L4.315 8.685a.98.98 0 01.837-.276c.47.07.802.48.968.925a2.501 2.501 0 103.214-3.214c-.446-.166-.855-.497-.925-.968a.979.979 0 01.276-.837l1.61-1.611a2.404 2.404 0 013.41 0l1.567 1.568c.23.23.556.338.877.29.493-.074.84-.504 1.02-.968a2.5 2.5 0 113.237 3.237c-.464.18-.894.527-.967 1.02z",
};

const statusVariant: Record<string, "accent" | "teal" | "muted"> = {
  "Launch direction": "accent",
  Planned: "teal",
  "In design": "teal",
  Roadmap: "muted",
  Exploratory: "muted",
};
---

<section id="features" class="py-20 md:py-28 bg-[var(--color-surface)]/50">
  <Container>
    <Reveal>
      <SectionHeading
        eyebrow="Platform direction"
        title="Designed for trust at every layer"
        description="From repositories to governance workflows, every feature is being designed with privacy, clarity, and long-term reliability in mind."
      />
    </Reveal>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        features.map((feature, i) => (
          <Reveal delay={Math.min(i * 50, 300)}>
            <div class="group p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-border-hover)] transition-all duration-200 h-full">
              <div class="flex items-start justify-between mb-4">
                <div class="p-2.5 rounded-lg bg-[var(--color-accent-muted)]">
                  <svg
                    class="h-5 w-5 text-[var(--color-accent)]"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d={iconPaths[feature.icon] || iconPaths.shield} />
                  </svg>
                </div>
                <Badge variant={statusVariant[feature.status] || "muted"}>
                  {feature.status}
                </Badge>
              </div>
              <h3 class="text-base font-semibold text-[var(--color-text)] mb-2">{feature.title}</h3>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
                {feature.description}
              </p>
            </div>
          </Reveal>
        ))
      }
    </div>
  </Container>
</section>
