---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import Reveal from "@/components/ui/Reveal.astro";
import { KICKSTARTER_URL, GITHUB_URL, WAITLIST_EMAIL, BASE_PATH } from "@/consts/site";
---

<section id="waitlist" class="relative py-20 md:py-28 bg-[var(--color-surface)]/50 overflow-hidden">
  <!-- Decorative gradient -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-[var(--color-accent)]/5 rounded-full blur-3xl"></div>
  </div>

  <Container class="relative z-10">
    <div class="max-w-2xl mx-auto text-center">
      <Reveal>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-bold tracking-tight text-[var(--color-text)] mb-5">
          Help shape a more transparent future for code
        </h2>
        <p class="text-base sm:text-lg text-[var(--color-text-secondary)] leading-relaxed mb-10">
          Repovera is at the beginning. The vision is clear, the direction is set, and the
          foundation is being built. Join early — as a backer, a developer, or a voice that
          believes developer infrastructure deserves better.
        </p>
      </Reveal>

      <Reveal delay={80}>
        <!--
          Waitlist form placeholder.
          Currently opens the user's email client with a pre-filled subject and body.
          Replace with a real form action (e.g., Formspree, Mailchimp, or custom endpoint)
          when backend integration is ready.
        -->
        <form
          id="waitlist-form"
          class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto mb-8"
        >
          <label class="sr-only" for="waitlist-email">Email address</label>
          <input
            id="waitlist-email"
            type="email"
            placeholder="you@example.com"
            required
            class="flex-1 px-4 py-2.5 rounded-lg bg-[var(--color-bg)] border border-[var(--color-border)] text-[var(--color-text)] text-sm placeholder:text-[var(--color-text-tertiary)] focus:border-[var(--color-accent)] focus:outline-none focus:ring-1 focus:ring-[var(--color-accent)] transition-colors"
          />
          <Button variant="primary" type="submit">
            Join Waitlist
          </Button>
        </form>
        <p class="text-xs text-[var(--color-text-tertiary)] mb-10">
          No spam. No data sharing. We will only reach out with meaningful launch updates.
        </p>
      </Reveal>

      <Reveal delay={120}>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
          <Button variant="kickstarter" href={KICKSTARTER_URL} target="_blank">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.204 8.086l-5.792 3.376V7.696L18.204 4v4.086zM12.412 12.622l5.792 3.376V20l-5.792-3.766v-3.612zM5.796 4.766v14.468L10.572 16V8L5.796 4.766z"/>
            </svg>
            Back on Kickstarter
          </Button>
          <Button variant="github" href={GITHUB_URL} target="_blank">
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.009-.866-.013-1.7-2.782.604-3.369-1.341-3.369-1.341-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
            </svg>
            Follow on GitHub
          </Button>
          <Button variant="secondary" href={`${BASE_PATH}/manifesto`}>
            Read the manifesto
          </Button>
        </div>
      </Reveal>
    </div>
  </Container>
</section>

<script define:vars={{ waitlistEmail: WAITLIST_EMAIL }}>
  const form = document.getElementById("waitlist-form");
  const emailInput = document.getElementById("waitlist-email");
  if (form && emailInput) {
    form.addEventListener("submit", (e) => {
      e.preventDefault();
      const email = emailInput.value;
      const subject = encodeURIComponent("Waitlist Signup");
      const body = encodeURIComponent(`I'd like to join the Repovera waitlist.\n\nMy email: ${email}`);
      window.location.href = `mailto:${waitlistEmail}?subject=${subject}&body=${body}`;
    });
  }
</script>
