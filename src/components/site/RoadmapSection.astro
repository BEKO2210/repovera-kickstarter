---
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Reveal from "@/components/ui/Reveal.astro";
import { roadmapPhases } from "@/data/roadmap";
import { BASE_PATH } from "@/consts/site";

const statusVariant: Record<string, "accent" | "teal" | "muted"> = {
  Active: "accent",
  Planned: "teal",
  "In design": "teal",
  Vision: "muted",
  Future: "muted",
  Exploratory: "muted",
};

const previewPhases = roadmapPhases.slice(0, 4);
---

<section id="roadmap" class="py-20 md:py-28">
  <Container>
    <Reveal>
      <SectionHeading
        eyebrow="Roadmap"
        title="A clear path forward"
        description="Repovera is being built in deliberate phases — each one expanding the platform's capabilities while maintaining the trust and quality standards that define the product."
      />
    </Reveal>

    <div class="grid sm:grid-cols-2 gap-5 mb-10">
      {
        previewPhases.map((phase, i) => (
          <Reveal delay={i * 80}>
            <div class="relative p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)] hover:border-[var(--color-border-hover)] transition-colors h-full">
              <div class="flex items-center justify-between mb-3">
                <span class="text-xs font-semibold text-[var(--color-text-tertiary)] uppercase tracking-wider">
                  Phase {phase.phase}
                </span>
                <Badge variant={statusVariant[phase.status] || "muted"}>
                  {phase.status}
                </Badge>
              </div>
              <h3 class="text-lg font-semibold text-[var(--color-text)] mb-2">{phase.title}</h3>
              <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-3">
                {phase.goal}
              </p>
              <p class="text-sm text-[var(--color-text-tertiary)] leading-relaxed">
                {phase.description.slice(0, 150)}…
              </p>
            </div>
          </Reveal>
        ))
      }
    </div>

    <Reveal>
      <div class="text-center">
        <Button variant="secondary" href={`${BASE_PATH}/roadmap`}>
          View full roadmap
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </Button>
      </div>
    </Reveal>
  </Container>
</section>
