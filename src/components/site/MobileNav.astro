---
import Button from "@/components/ui/Button.astro";
import { NAV_LINKS } from "@/consts/navigation";
import { KICKSTARTER_URL, BASE_PATH } from "@/consts/site";
---

<div class="md:hidden">
  <button
    id="mobile-nav-toggle"
    type="button"
    class="p-2 text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors"
    aria-label="Open navigation menu"
    aria-expanded="false"
    aria-controls="mobile-nav-panel"
  >
    <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <path id="menu-icon" stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
      <path id="close-icon" class="hidden" stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <div
    id="mobile-nav-panel"
    class="hidden fixed inset-x-0 top-16 bottom-0 bg-[var(--color-bg)]/95 backdrop-blur-xl z-40 border-t border-[var(--color-border)]"
    role="dialog"
    aria-label="Navigation menu"
  >
    <nav class="flex flex-col p-6 gap-2" aria-label="Mobile navigation">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
            class="block py-3 px-4 text-base text-[var(--color-text-secondary)] hover:text-[var(--color-text)] hover:bg-[var(--color-surface)] rounded-lg transition-colors"
          >
            {link.label}
          </a>
        ))
      }
      <div class="mt-4 pt-4 border-t border-[var(--color-border)] flex flex-col gap-3">
        <Button variant="kickstarter" href={KICKSTARTER_URL} target="_blank">
          Back on Kickstarter
        </Button>
        <Button variant="primary" href={`${BASE_PATH}/#waitlist`}>
          Join Waitlist
        </Button>
      </div>
    </nav>
  </div>
</div>

<script>
  const toggle = document.getElementById("mobile-nav-toggle");
  const panel = document.getElementById("mobile-nav-panel");
  const menuIcon = document.getElementById("menu-icon");
  const closeIcon = document.getElementById("close-icon");

  if (toggle && panel && menuIcon && closeIcon) {
    toggle.addEventListener("click", () => {
      const isOpen = toggle.getAttribute("aria-expanded") === "true";
      toggle.setAttribute("aria-expanded", String(!isOpen));
      toggle.setAttribute("aria-label", isOpen ? "Open navigation menu" : "Close navigation menu");
      panel.classList.toggle("hidden");
      menuIcon.classList.toggle("hidden");
      closeIcon.classList.toggle("hidden");
      document.body.style.overflow = isOpen ? "" : "hidden";
    });

    panel.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", () => {
        toggle.setAttribute("aria-expanded", "false");
        panel.classList.add("hidden");
        menuIcon.classList.remove("hidden");
        closeIcon.classList.add("hidden");
        document.body.style.overflow = "";
      });
    });
  }
</script>
