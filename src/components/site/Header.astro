---
import Container from "@/components/ui/Container.astro";
import LogoMark from "@/components/ui/LogoMark.astro";
import Button from "@/components/ui/Button.astro";
import MobileNav from "@/components/site/MobileNav.astro";
import { NAV_LINKS } from "@/consts/navigation";
import { KICKSTARTER_URL, BASE_PATH } from "@/consts/site";
---

<header
  id="site-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 border-b border-transparent"
>
  <Container class="flex items-center justify-between h-16">
    <LogoMark />

    <nav class="hidden md:flex items-center gap-6" aria-label="Main navigation">
      {
        NAV_LINKS.map((link) => (
          <a
            href={link.href}
            target={link.external ? "_blank" : undefined}
            rel={link.external ? "noopener noreferrer" : undefined}
            class="text-sm text-[var(--color-text-secondary)] hover:text-[var(--color-text)] transition-colors duration-200"
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="hidden md:flex items-center gap-3">
      <Button variant="kickstarter" size="sm" href={KICKSTARTER_URL} target="_blank">
        Back on Kickstarter
      </Button>
      <Button variant="primary" size="sm" href={`${BASE_PATH}/#waitlist`}>
        Join Waitlist
      </Button>
    </div>

    <MobileNav />
  </Container>
</header>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    const onScroll = () => {
      if (window.scrollY > 20) {
        header.classList.add(
          "bg-[var(--color-bg)]/90",
          "backdrop-blur-lg",
          "border-b",
          "border-[var(--color-border)]",
        );
      } else {
        header.classList.remove(
          "bg-[var(--color-bg)]/90",
          "backdrop-blur-lg",
          "border-[var(--color-border)]",
        );
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    onScroll();
  }
</script>
