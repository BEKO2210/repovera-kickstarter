---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Header from "@/components/site/Header.astro";
import Container from "@/components/ui/Container.astro";
import Badge from "@/components/ui/Badge.astro";
import Button from "@/components/ui/Button.astro";
import Reveal from "@/components/ui/Reveal.astro";
import Footer from "@/components/site/Footer.astro";
import { roadmapPhases } from "@/data/roadmap";
import { KICKSTARTER_URL, GITHUB_URL, BASE_PATH } from "@/consts/site";

const statusVariant: Record<string, "accent" | "teal" | "muted"> = {
  Active: "accent",
  Planned: "teal",
  "In design": "teal",
  Vision: "muted",
  Future: "muted",
  Exploratory: "muted",
};
---

<BaseLayout
  title="Roadmap — Repovera"
  description="The Repovera product roadmap: a clear, phased approach to building trusted code infrastructure."
>
  <Header />
  <main id="main" class="pt-28 pb-20">
    <Container>
      <div class="max-w-3xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-widest text-[var(--color-accent)] mb-4">
          Roadmap
        </p>
        <h1 class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-[var(--color-text)] mb-6">
          Building in deliberate phases
        </h1>
        <p class="text-lg text-[var(--color-text-secondary)] leading-relaxed mb-16">
          Repovera is being built with care, not speed. Each phase expands the platform's
          capabilities while maintaining the quality, trust, and transparency standards that
          define the product. This roadmap reflects our current direction — it will evolve as
          the platform and community grow.
        </p>

        <div class="space-y-8">
          {
            roadmapPhases.map((phase, i) => (
              <Reveal delay={i * 60}>
                <div class="relative pl-8 pb-8 border-l-2 border-[var(--color-border)] last:border-l-0 last:pb-0">
                  <div class="absolute left-0 top-0 -translate-x-1/2 w-4 h-4 rounded-full bg-[var(--color-surface)] border-2 border-[var(--color-accent)]" />

                  <div class="p-6 rounded-xl bg-[var(--color-surface)] border border-[var(--color-border)]">
                    <div class="flex flex-wrap items-center gap-3 mb-3">
                      <span class="text-xs font-semibold text-[var(--color-text-tertiary)] uppercase tracking-wider">
                        Phase {phase.phase}
                      </span>
                      <Badge variant={statusVariant[phase.status] || "muted"}>
                        {phase.status}
                      </Badge>
                    </div>

                    <h2 class="text-xl font-semibold text-[var(--color-text)] mb-2">
                      {phase.title}
                    </h2>
                    <p class="text-sm font-medium text-[var(--color-accent)] mb-3">
                      {phase.goal}
                    </p>
                    <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed mb-4">
                      {phase.description}
                    </p>

                    <div class="pt-3 border-t border-[var(--color-border)]">
                      <p class="text-xs font-medium text-[var(--color-text-tertiary)] uppercase tracking-wider mb-1">
                        User value
                      </p>
                      <p class="text-sm text-[var(--color-text-secondary)] leading-relaxed">
                        {phase.userValue}
                      </p>
                    </div>
                  </div>
                </div>
              </Reveal>
            ))
          }
        </div>

        <Reveal>
          <div class="mt-16 pt-8 border-t border-[var(--color-border)] text-center">
            <p class="text-sm text-[var(--color-text-tertiary)] mb-6">
              This roadmap represents our current direction. Phases, timelines, and priorities
              may evolve as the platform and community grow. We build in the open — follow
              along.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
              <Button variant="kickstarter" href={KICKSTARTER_URL} target="_blank">
                Back on Kickstarter
              </Button>
              <Button variant="github" href={GITHUB_URL} target="_blank">
                Follow on GitHub
              </Button>
              <Button variant="secondary" href={`${BASE_PATH}/`}>
                Back to home
              </Button>
            </div>
          </div>
        </Reveal>
      </div>
    </Container>
  </main>
  <Footer />
</BaseLayout>
